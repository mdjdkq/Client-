-- SCRIPT QUÉT WANTED HIỂN THỊ TRÊN MÀN HÌNH MOBILE
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Khởi tạo UI hiển thị kết quả trực tiếp
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ScanResultMobile"
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 300, 0, 200)
Frame.Position = UDim2.new(0.5, -150, 0.3, 0)
Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Frame.Active = true
Frame.Draggable = true
Frame.Parent = ScreenGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
Title.Text = "KẾT QUẢ QUÉT WANTED"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 14
Title.Parent = Frame

local TextBox = Instance.new("TextBox")
TextBox.Size = UDim2.new(1, -10, 1, -40)
TextBox.Position = UDim2.new(0, 5, 0, 35)
TextBox.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
TextBox.TextColor3 = Color3.fromRGB(0, 255, 140)
TextBox.TextSize = 12
TextBox.Font = Enum.Font.Code
TextBox.ClearTextOnFocus = false
TextBox.MultiLine = true
TextBox.ReadOnly = true
TextBox.TextXAlignment = Enum.TextXAlignment.Left
TextBox.TextYAlignment = Enum.TextYAlignment.Top
TextBox.Parent = Frame

local resultText = "Đang quét...\n"
TextBox.Text = resultText

local found = false
local function scan(root, description)
    for _, obj in pairs(root:GetDescendants()) do
        local name = string.lower(obj.Name)
        if string.find(name, "wanted") or string.find(name, "bounty") or string.find(name, "criminal") then
            resultText = resultText .. description .. " -> " .. obj.Name .. " (" .. obj.ClassName .. ")\n"
            TextBox.Text = resultText
            found = true
        end
    end
end

-- Tiến hành quét
scan(ReplicatedStorage, "[Repo]")
scan(LocalPlayer.PlayerGui, "[UI]")

if not found then
    resultText = resultText .. "Chưa tìm thấy mục tiêu. Hãy chắc chắn bạn đã vào phe Cảnh sát và BẤM MỞ MỤC POLICE TRÊN ĐIỆN THOẠI TRONG GAME rồi chạy lại script!"
    TextBox.Text = resultText
else
    resultText = resultText .. "--- QUÉT XONG! ---"
    TextBox.Text = resultText
end
