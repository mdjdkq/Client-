-- HÀM LOGIC QUÉT MÀU SẮC THEO TRUY NÃ & VAI TRÒ
local function GetRoleInfo(player)
    if not player then return Color3.fromRGB(255, 255, 255), true end
    
    -- [KIỂM TRA TRUY NÃ / WANTED / BOUNTY] -> ƯU TIÊN SỐ 1
    local isWanted = false
    
    -- Tìm trong leaderstats (Bounty hoặc Wanted)
    local leaderstats = player:FindFirstChild("leaderstats") or player:FindFirstChild("Leaderstats")
    if leaderstats then
        local bounty = leaderstats:FindFirstChild("Bounty") or leaderstats:FindFirstChild("Wanted") or leaderstats:FindFirstChild("Truy Nã")
        if bounty and bounty:IsA("ValueBase") and tonumber(bounty.Value) and tonumber(bounty.Value) > 0 then
            isWanted = true
        end
    end
    -- Tìm trực tiếp thuộc tính Wanted/Bounty dưới Player
    local directWanted = player:FindFirstChild("Wanted") or player:FindFirstChild("IsWanted") or player:FindFirstChild("Bounty")
    if directWanted and directWanted:IsA("ValueBase") then
        if (directWanted:IsA("BoolValue") and directWanted.Value == true) or (tonumber(directWanted.Value) and tonumber(directWanted.Value) > 0) then
            isWanted = true
        end
    end
    
    -- Nếu bị truy nã -> Đổi ngay sang màu ĐỎ rực và bật Aim công khai
    if isWanted then
        return Color3.fromRGB(255, 0, 0), true
    end

    -- [KIỂM TRA THEO VAI TRÒ MẶC ĐỊNH NẾU KHÔNG BỊ TRUY NÃ]
    local teamName = ""
    if player.Team then teamName = player.Team.Name
    elseif leaderstats and leaderstats:FindFirstChild("Role") then teamName = leaderstats.Role.Value
    elseif player:FindFirstChild("Role") then teamName = player.Role.Value end
    
    local lowerTeam = string.lower(tostring(teamName))
    if string.find(lowerTeam, "police") or string.find(lowerTeam, "cảnh sát") or string.find(lowerTeam, "cop") then
        return Color3.fromRGB(0, 100, 255), true -- Xanh dương
    elseif string.find(lowerTeam, "criminal") or string.find(lowerTeam, "tội phạm") or string.find(lowerTeam, "robber") then
        return Color3.fromRGB(255, 50, 50), true -- Đỏ thường
    elseif string.find(lowerTeam, "fire") or string.find(lowerTeam, "cứu hỏa") then
        return Color3.fromRGB(255, 105, 180), false -- Hồng (Không aim)
    elseif string.find(lowerTeam, "rescue") or string.find(lowerTeam, "cứu hộ") or string.find(lowerTeam, "ems") or string.find(lowerTeam, "medic") then
        return Color3.fromRGB(255, 215, 0), false -- Vàng (Không aim)
    elseif string.find(lowerTeam, "truck") or string.find(lowerTeam, "xe tải") then
        return Color3.fromRGB(50, 255, 50), false -- Xanh lá (Không aim)
    elseif string.find(lowerTeam, "bus") or string.find(lowerTeam, "xe bus") then
        return Color3.fromRGB(0, 0, 0), false -- Đen (Không aim)
    else
        return Color3.fromRGB(255, 255, 255), true -- Dân thường: Trắng
    end
end

-- HÀM TÌM TÂM MỤC TIÊU GẦN NHẤT
local function GetClosestTarget()
    local MaximumDistance = Settings.FOV
    local Target = nil
    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local isSameTeam = false
            if LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then isSameTeam = true end
            
            if not isSameTeam then
                local _, AllowAim = GetRoleInfo(player)
                if AllowAim then 
                    local Humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    local TargetPart = player.Character:FindFirstChild(Settings.TargetPart)
                    
                    if TargetPart and Humanoid and Humanoid.Health > 0 then
                        local ScreenPosition, OnScreen = Camera:WorldToScreenPoint(TargetPart.Position)
                        if OnScreen then
                            local Distance = (Vector2.new(ScreenPosition.X, ScreenPosition.Y) - ScreenCenter).Magnitude
                            if Distance < MaximumDistance then
                                MaximumDistance = Distance
                                Target = TargetPart
                            end
                        end
                    end
                end
            end
        end
    end
    return Target
end

-- HÀM TẠO ESP
local function CreateESP(player)
    if player == LocalPlayer then return end

    local Box = Drawing.new("Square")
    Box.Visible = false; Box.Thickness = 1.5; Box.Filled = false

    local Name = Drawing.new("Text")
    Name.Visible = false; Name.Size = 14; Name.Center = true; Name.Outline = true

    local HealthBar = Drawing.new("Square")
    HealthBar.Visible = false; HealthBar.Thickness = 1; HealthBar.Filled = true

    shared.ESPCache[player] = {Box = Box, Name = Name, HealthBar = HealthBar}

    local function UpdateESP()
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") or not player.Character:FindFirstChildOfClass("Humanoid") or player.Character:FindFirstChildOfClass("Humanoid").Health <= 0 then
                Box.Visible = false; Name.Visible = false; HealthBar.Visible = false
                if not player.Parent then
                    pcall(function() Box:Remove() end)
                    pcall(function() Name:Remove() end)
                    pcall(function() HealthBar:Remove() end)
                    shared.ESPCache[player] = nil; connection:Disconnect()
                end
                return
            end

            local RootPart = player.Character.HumanoidRootPart
            local Humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            local RootPos, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)

            if OnScreen and Settings.ESP then
                local RoleColor, _ = GetRoleInfo(player)
                local Head = player.Character:FindFirstChild("Head")
                local HeadPos = Head and Camera:WorldToViewportPoint(Head.Position) or RootPos
                local ScaleY = math.abs(HeadPos.Y - RootPos.Y) * 3
                local ScaleX = ScaleY / 1.5

                Box.Size = Vector2.new(ScaleX, ScaleY)
                Box.Position = Vector2.new(RootPos.X - ScaleX / 2, RootPos.Y - ScaleY / 2)
                Box.Color = RoleColor; Box.Visible = true

                if Settings.ESPName then
                    Name.Position = Vector2.new(RootPos.X, (RootPos.Y - ScaleY / 2) - 15)
                    Name.Text = player.Name; Name.Color = RoleColor; Name.Visible = true
                else Name.Visible = false end

                if Settings.Health then
                    local HealthPercentage = math.clamp(Humanoid.Health / Humanoid.MaxHealth, 0, 1)
                    HealthBar.Size = Vector2.new(3, ScaleY * HealthPercentage)
                    HealthBar.Position = Vector2.new((RootPos.X - ScaleX / 2) - 6, (RootPos.Y + ScaleY / 2) - (ScaleY * HealthPercentage))
                    HealthBar.Color = Color3.fromRGB(255 - (255 * HealthPercentage), 255 * HealthPercentage, 0); HealthBar.Visible = true
                else HealthBar.Visible = false end
            else
                Box.Visible = false; Name.Visible = false; HealthBar.Visible = false
            end
        end)
        table.insert(shared.ESPConnections, connection)
    end
    coroutine.wrap(UpdateESP)()
end

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
table.insert(shared.ESPConnections, Players.PlayerAdded:Connect(CreateESP))

