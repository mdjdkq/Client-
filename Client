-- LOGIC ĐIỀU KHIỂN BẰNG PHÍM (Bấm phím để chỉnh thay vì click chuột vào UI để không bị lỗi click xuyên)
table.insert(shared.MenuRenderConnections, UserInputService.InputBegan:Connect(function(input, processed)
    if input.KeyCode == Enum.KeyCode.Insert then
        Settings.MenuVisible = not Settings.MenuVisible
        for _, el in pairs(shared.MenuElements) do el.Visible = Settings.MenuVisible end
    elseif Settings.MenuVisible then
        if input.KeyCode == Enum.KeyCode.F4 then
            Settings.Enabled = not Settings.Enabled
            BtnAimbot.Text = Settings.Enabled and "Aimbot: [ BẬT ] (Click F4 để đổi)" or "Aimbot: [ TẮT ] (Click F4 để đổi)"
            BtnAimbot.Color = Settings.Enabled and Color3.fromRGB(100, 255, 150) or Color3.fromRGB(255, 100, 100)
        elseif input.KeyCode == Enum.KeyCode.F5 then
            if Settings.TargetPart == "Head" then
                Settings.TargetPart = "HumanoidRootPart"
                BtnTarget.Text = "Mục tiêu: [ THÂN ] (Click F5 để đổi)"
            else
                Settings.TargetPart = "Head"
                BtnTarget.Text = "Mục tiêu: [ ĐẦU ] (Click F5 để đổi)"
            end
        elseif input.KeyCode == Enum.KeyCode.F6 then
            Settings.ESP = not Settings.ESP
            BtnESP.Text = Settings.ESP and "Khung ESP: [ BẬT ] (Click F6 để đổi)" or "Khung ESP: [ TẮT ] (Click F6 để đổi)"
            BtnESP.Color = Settings.ESP and Color3.fromRGB(100, 255, 150) or Color3.fromRGB(255, 100, 100)
        elseif input.KeyCode == Enum.KeyCode.F7 then
            Settings.FOV = Settings.FOV + 40
            if Settings.FOV > 300 then Settings.FOV = 60 end
            BtnFOV.Text = "Vòng FOV: [ " .. Settings.FOV .. " ] (Click F7 để tăng)"
        end
    end
end))

