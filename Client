-- HÀM THU THẬP THÔNG TIN VAI TRÒ & TRUY NÃ AN TOÀN TRÁNH CRASH
local function GetRoleInfo(player)
    if not player then return Color3.fromRGB(255, 255, 255), true end
    local isWanted = false
    
    -- Kiểm tra trạng thái truy nã an toàn
    pcall(function()
        local leaderstats = player:FindFirstChild("leaderstats") or player:FindFirstChild("Leaderstats")
        if leaderstats then
            local b = leaderstats:FindFirstChild("Bounty") or leaderstats:FindFirstChild("Wanted") or leaderstats:FindFirstChild("Stars")
            if b and tonumber(b.Value) and tonumber(b.Value) > 0 then isWanted = true end
        end
        if not isWanted then
            local pd = player:FindFirstChild("PlayerData") or player:FindFirstChild("Data")
            if pd then
                local w = pd:FindFirstChild("Wanted") or pd:FindFirstChild("WantedLevel") or pd:FindFirstChild("Bounty")
                if w and (w.Value == true or (tonumber(w.Value) and tonumber(w.Value) > 0)) then isWanted = true end
            end
        end
    end)

    if isWanted then return Color3.fromRGB(255, 0, 0), true end -- Đỏ rực nếu bị truy nã

    local teamName = player.Team and player.Team.Name or ""
    local lowerTeam = string.lower(teamName)
    
    if string.find(lowerTeam, "police") or string.find(lowerTeam, "cảnh sát") or string.find(lowerTeam, "sek") or string.find(lowerTeam, "cop") then
        return Color3.fromRGB(0, 120, 255), true
    elseif string.find(lowerTeam, "criminal") or string.find(lowerTeam, "tội phạm") then
        return Color3.fromRGB(255, 60, 60), true
    elseif string.find(lowerTeam, "fire") or string.find(lowerTeam, "cứu hỏa") or string.find(lowerTeam, "medic") or string.find(lowerTeam, "ems") then
        return Color3.fromRGB(255, 215, 0), false -- Màu vàng (Không tự động khóa tâm nhầm đồng đội cứu hộ)
    else
        return Color3.fromRGB(255, 255, 255), true -- Dân thường: Trắng
    end
end

-- TÌM MỤC TIÊU GẦN NHẤT
local function GetClosestTarget()
    local MaximumDistance = Settings.FOV
    local Target = nil
    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local isSameTeam = (LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team)
            if not isSameTeam then
                local _, AllowAim = GetRoleInfo(player)
                if AllowAim then 
                    local Humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    local TargetPart = player.Character:FindFirstChild(Settings.TargetPart)
                    if TargetPart and Humanoid and Humanoid.Health > 0 then
                        local ScreenPosition, OnScreen = Camera:WorldToScreenPoint(TargetPart.Position)
                        if OnScreen then
                            local Distance = (Vector2.new(ScreenPosition.X, ScreenPosition.Y) - ScreenCenter).Magnitude
                            if Distance < MaximumDistance then
                                MaximumDistance = Distance
                                Target = TargetPart
                            end
                        end
                    end
                end
            end
        end
    end
    return Target
end

-- ESP CHUẨN ĐỒ HỌA TUYỆT ĐỐI KHÔNG BỊ PHÁT HIỆN
local function CreateESP(player)
    if player == LocalPlayer then return end
    local Box = Drawing.new("Square"); Box.Visible = false; Box.Thickness = 1.5; Box.Filled = false
    local Name = Drawing.new("Text"); Name.Visible = false; Name.Size = 13; Name.Center = true; Name.Outline = true
    local HealthBar = Drawing.new("Square"); HealthBar.Visible = false; HealthBar.Thickness = 1; HealthBar.Filled = true

    shared.ESPCache[player] = {Box = Box, Name = Name, HealthBar = HealthBar}

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") or not player.Character:FindFirstChildOfClass("Humanoid") or player.Character:FindFirstChildOfClass("Humanoid").Health <= 0 then
            Box.Visible = false; Name.Visible = false; HealthBar.Visible = false
            if not player.Parent then
                pcall(function() Box:Remove() end)
                pcall(function() Name:Remove() end)
                pcall(function() HealthBar:Remove() end)
                shared.ESPCache[player] = nil; connection:Disconnect()
            end
            return
        end

        local RootPart = player.Character.HumanoidRootPart
        local Humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        local RootPos, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)

        if OnScreen and Settings.ESP then
            local RoleColor, _ = GetRoleInfo(player)
            local Head = player.Character:FindFirstChild("Head")
            local HeadPos = Head and Camera:WorldToViewportPoint(Head.Position) or RootPos
            local ScaleY = math.abs(HeadPos.Y - RootPos.Y) * 3
            local ScaleX = ScaleY / 1.5

            Box.Size = Vector2.new(ScaleX, ScaleY)
            Box.Position = Vector2.new(RootPos.X - ScaleX / 2, RootPos.Y - ScaleY / 2)
            Box.Color = RoleColor; Box.Visible = true

            if Settings.ESPName then
                Name.Position = Vector2.new(RootPos.X, (RootPos.Y - ScaleY / 2) - 15)
                Name.Text = player.Name; Name.Color = RoleColor; Name.Visible = true
            else Name.Visible = false end

            if Settings.Health then
                local HealthPercentage = math.clamp(Humanoid.Health / Humanoid.MaxHealth, 0, 1)
                HealthBar.Size = Vector2.new(2, ScaleY * HealthPercentage)
                HealthBar.Position = Vector2.new((RootPos.X - ScaleX / 2) - 5, (RootPos.Y + ScaleY / 2) - (ScaleY * HealthPercentage))
                HealthBar.Color = Color3.fromRGB(255 - (255 * HealthPercentage), 255 * HealthPercentage, 0); HealthBar.Visible = true
            else HealthBar.Visible = false end
        else
            Box.Visible = false; Name.Visible = false; HealthBar.Visible = false
        end
    end)
    table.insert(shared.ESPConnections, connection)
end

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
table.insert(shared.ESPConnections, Players.PlayerAdded:Connect(CreateESP))

-- CHẾ TẠO MENU THUẦN DRAWING (ANTI-BAN & ANTI-DELETE TUYỆT ĐỐI)
local MenuPos = Vector2.new(150, 200)
local MenuSize = Vector2.new(240, 210)

local function CreateMenuText(text, pos, size, color)
    local t = Drawing.new("Text")
    t.Text = text; t.Position = pos; t.Size = size; t.Color = color; t.Outline = true; t.Visible = true
    table.insert(shared.MenuElements, t)
    return t
end

local function CreateMenuSquare(pos, size, color, thickness, filled)
    local s = Drawing.new("Square")
    s.Position = pos; s.Size = size; s.Color = color; s.Thickness = thickness; s.Filled = filled; s.Visible = true
    table.insert(shared.MenuElements, s)
    return s
end

