-- MENU ĐIỀU KHIỂN BẰNG PHÍM ẢO TRÊN MÀN HÌNH (DÀNH CHO MOBILE)
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Settings = {Enabled = false, ESP = true, FOV = 120}

-- TẠO NÚT BẤM ẢO TRÊN MÀN HÌNH ĐỂ ĐIỀU KHIỂN
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local ToggleBtn = Instance.new("TextButton", ScreenGui)
ToggleBtn.Size = UDim2.new(0, 100, 0, 50)
ToggleBtn.Position = UDim2.new(0.5, -50, 0, 10)
ToggleBtn.Text = "AIM: TẮT"
ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)

ToggleBtn.MouseButton1Click:Connect(function()
    Settings.Enabled = not Settings.Enabled
    ToggleBtn.Text = Settings.Enabled and "AIM: BẬT" or "AIM: TẮT"
    ToggleBtn.BackgroundColor3 = Settings.Enabled and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
end)

-- LOGIC AIMBOT ĐƠN GIẢN
RunService.RenderStepped:Connect(function()
    if Settings.Enabled then
        local closestPlayer = nil
        local shortestDist = Settings.FOV
        
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
                local pos, onScreen = Camera:WorldToScreenPoint(player.Character.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < shortestDist then
                        closestPlayer = player.Character.Head
                        shortestDist = dist
                    end
                end
            end
        end
        if closestPlayer then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, closestPlayer.Position)
        end
    end
end)

